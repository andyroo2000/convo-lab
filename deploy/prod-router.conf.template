map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

map $http_x_forwarded_proto $proxy_x_forwarded_proto {
    default $http_x_forwarded_proto;
    '' $scheme;
}

map $http_x_xsrf_token $learning_os_xsrf_token {
    default $http_x_xsrf_token;
    '' $http_x_csrf_token;
}

server {
    listen 3001;
    server_name _;
    client_max_body_size 50m;

    resolver 127.0.0.11 valid=5s ipv6=off;
    set $convolab_upstream http://__UPSTREAM_SERVICE__:3001;
    set $learning_os_upstream http://learning-os:8080;

    location = /nginx-health {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    location = /sanctum/csrf-cookie {
        proxy_pass $learning_os_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $proxy_x_forwarded_proto;
        proxy_set_header Authorization "";
        proxy_set_header X-Convo-Lab-User-Id "";
        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
    }

    location ^~ /api/convolab/auth/ {
        proxy_pass $learning_os_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $proxy_x_forwarded_proto;
        proxy_set_header Authorization "";
        proxy_set_header X-Convo-Lab-User-Id "";
        proxy_buffering off;
        proxy_connect_timeout 5s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
    }

    location ~ ^/api/convolab/browser/auth(?:/|$) {
        proxy_pass $learning_os_upstream;
        proxy_http_version 1.1;
