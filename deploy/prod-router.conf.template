    # Keep this regex synchronized with studyRouteContract.ts; its contract test enforces equality.
    location ~ "^/api/learning-os/study/imports/[0-9A-HJKMNP-TV-Za-hjkmnp-tv-z]{26}/upload$" {
        client_max_body_size 2g;
        proxy_pass $convolab_upstream;
        proxy_http_version 1.1;
        proxy_request_buffering off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $proxy_x_forwarded_proto;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering off;
        proxy_connect_timeout 5s;
        proxy_send_timeout 1800s;
        proxy_read_timeout 1800s;
    }

    location ~ "^/api/study/imports/[0-9A-HJKMNP-TV-Za-hjkmnp-tv-z]{26}/upload$" {
