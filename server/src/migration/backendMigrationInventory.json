{
  "schemaVersion": 1,
  "targetService": "learning-os",
  "surfaces": [
    {
      "id": "csrf",
      "domain": "security",
      "migrationWave": "retirement",
      "runtimeOwner": "express",
      "sourceFile": "server/src/routes/csrf.ts",
      "mountPath": "/api/auth/csrf",
      "routes": [
        {
          "id": "csrf.bootstrap",
          "method": "GET",
          "path": "/api/auth/csrf"
        }
      ]
    },
    {
      "id": "study",
      "domain": "study",
      "migrationWave": "complete",
      "runtimeOwner": "learning-os-proxy",
      "sourceFile": "server/src/routes/learningOs/study.ts",
      "mountPath": "/api/learning-os/study",
      "routes": [
        {
          "id": "study.proxy",
          "method": "ALL",
          "path": "/api/learning-os/study/*"
        }
      ]
    }
  ]
}
